# Supabase — obtenha em app.supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic — obtenha em console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# YouTube Data API v3 — console.cloud.google.com (grátis, 10k unidades/dia)
# Sem esta chave, as tendências usam só o Reddit (que não precisa de chave).
YOUTUBE_API_KEY=

# Segredo do cron do Vercel (qualquer string aleatória). Usado para autenticar
# o job diário /api/trends/sync. Configure o mesmo valor no Vercel.
CRON_SECRET=

# Replicate — replicate.com/account/api-tokens (geração de imagem IA dos slides)
# Modelos: Flux 1.1 Pro, Flux Dev, Ideogram, Nano Banana.
REPLICATE_API_TOKEN=
